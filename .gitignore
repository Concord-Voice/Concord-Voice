# AWS
.aws/
*.pem
aws-exports.js

# Track cert-pinning test fixtures (issue #658). Negation must come AFTER
# every *.pem rule above (gitignore applies later rules last). These are
# synthetic self-signed PEMs with zero production value — regenerated via
# client/desktop/tests/fixtures/pinning/generate.mjs for deterministic tests.
!client/desktop/tests/fixtures/pinning/*.pem

# Google Cloud
*-key.json
gcloud-service-key.json

# Session storage (root-level only, not internal/sessions/)
/.sessions/
/sessions/
.dev-data/
snapshots/

# Claude Code per-branch transient state (e.g., hook-bypass markers from
# the /superpowers:brainstorming + /superpowers:writing-plans authorization
# flow per #1136). These files are per-developer, per-branch authorizations
# for the protect-sensitive.sh hook — accidentally committing one would
# leak authorization to all clones. Keep transient.
/[internal]state/

# Superpowers brainstorm visual-companion artifacts (local only)
.superpowers/

# ZAP API DAST local-run scan output (#1465) — CI consumes it in-job only
/reports/
# Python bytecode from the .zap/ DAST helpers (#1465)
.zap/__pycache__/
