# Concord Voice Control Plane - Environment Variables Template
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=postgres://concord:your_password_here@localhost:5432/concord?sslmode=disable

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Secret (CHANGE THIS IN PRODUCTION!)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_secret_key_here

# Server Configuration
PORT=8080
ENVIRONMENT=development

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=info

# Optional: Rate Limiting
RATE_LIMIT_ENABLED=true

# Trusted reverse-proxy CIDRs (comma-separated IPv4/IPv6 CIDRs).
# REQUIRED in production — an unset value fails startup via config validate().
# In non-production (development/staging/CI), an unset value falls back to
# 172.16.0.0/12 (broad RFC1918 Docker range). The docker-compose bridge
# network typically uses 172.19.0.0/16, which is the tighter value pinned
# here and in the compose file. Malformed CIDRs fail startup in all envs.
# Without a correct value, c.ClientIP() returns the nginx container address
# and breaks IP-based rate limiting, authban, session audit, and observability.
TRUSTED_PROXY_CIDRS=172.19.0.0/16

# Optional: NATS Configuration (for future use)
# NATS_URL=nats://localhost:4222
