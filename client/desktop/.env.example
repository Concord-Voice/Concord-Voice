# Concord Voice Desktop Client - Environment Variables Template
# Copy this file to .env for local development

# Server connection (default: localhost for local dev)
# For LAN/staging: set to the server's IP or hostname
VITE_SERVER_HOST=localhost
VITE_API_PORT=8080
VITE_USE_TLS=false

# Environment
VITE_ENVIRONMENT=development

# Logging
VITE_LOG_LEVEL=debug

# Optional: Analytics (disabled in dev)
VITE_ANALYTICS_ENABLED=false
