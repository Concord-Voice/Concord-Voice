{
  "name": "@concordvoice/desktop",
  "productName": "Concord Voice",
  "version": "0.2.5",
  "description": "Concord Voice Desktop Client - Privacy-first voice communication",
  "main": "dist/main/main.js",
  "author": "Concord Voice Team",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "npm run build:preload && tsc -p tsconfig.main.json && NODE_ENV=development electron-forge start",
    "build": "npm run build:renderer && npm run build:preload && npm run build:main",
    "build:renderer": "vite build",
    "build:preload": "node scripts/build-preload.mjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build:buildtag": "node scripts/generate-buildtag.mjs",
    "build:gclientsecret": "node scripts/generate-google-client-secret.mjs",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "postinstall": "bash scripts/patch-electron-plist.sh || true",
    "lint": "eslint . --ignore-pattern 'tests/**'",
    "lint:fix": "eslint . --ignore-pattern 'tests/**' --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "preview:splash": "npm run build:main && electron dist/main/splashPreview.js",
    "build:emoji-shortcodes": "NODE_PATH=./node_modules tsx ../../scripts/build-emoji-shortcodes.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "electron-squirrel-startup": "^1.0.0",
    "electron-updater": "^6.8.9",
    "hash-wasm": "^4.12.0",
    "jose": "6.2.3",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.21.0",
    "mediasoup-client": "^3.21.0",
    "minisearch": "^7.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "use-sync-external-store": "^1.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "^5.9.2",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@playwright/test": "^1.61.0",
    "@reforged/maker-appimage": "^5.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "app-builder-bin": "^4.2.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "gemoji": "^8.1.0",
    "globals": "^17.7.0",
    "ioredis": "^5.11.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "selfsigned": "^5.5.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "unicode-emoji-json": "^0.9.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.18",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "tar": "^7.5.16",
    "@tootallnate/once": "^3.0.1",
    "tmp": "^0.2.7",
    "serialize-javascript": "^7.0.3",
    "minimatch": "^9.0.7",
    "rollup": "^4.59.0",
    "fast-uri": "^3.1.2",
    "ws": "^8.21.0",
    "undici": "^7.28.0",
    "@babel/core": "^7.29.6"
  },
  "optionalDependencies": {
    "@noble/hashes": "^2.2.0"
  }
}
