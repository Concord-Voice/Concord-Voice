{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,
    "lib": ["ES2022"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/preload/**/*"],
  "exclude": ["node_modules", "dist", "src/renderer", "src/main"]
}
