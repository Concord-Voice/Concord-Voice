# Concord Voice Docker Compose Environment Variables
# Copy this file to .env and adjust values for your environment.
# concord-dev.sh up will auto-copy this file to .env if .env does not exist.
#
# PRODUCTION: Do NOT use these values. Use provision-secrets.yml to set
# real secrets via GitHub environment secrets.

# PostgreSQL
POSTGRES_PASSWORD=concord_dev_password

# Redis
REDIS_PASSWORD=concord_dev_redis

# JWT Secret (MUST change in production)
JWT_SECRET=dev_jwt_secret_change_in_production

# TURN/STUN (coturn)
TURN_SECRET=concord_dev_turn_secret
# PUBLIC_IP is REQUIRED. coturn advertises this address in CANDIDATE/ALLOCATION
# responses — clients connect back to it for relayed media. For local dev set
# it to your LAN IP (e.g. 192.168.1.42); for production set it to the host's
# public IPv4. In production this is written automatically by provision-secrets.yml
# from the `server_host` workflow input. If unset, docker compose will refuse to start.
PUBLIC_IP=127.0.0.1

# Object Storage (MinIO)
MINIO_ROOT_USER=concord
MINIO_ROOT_PASSWORD=concord_dev_minio

# pgAdmin (optional, dev tools profile)
PGADMIN_PASSWORD=admin
