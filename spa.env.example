# spa.env.example — placeholder consumed by the PUBLISHED docker-compose.yml.
# The real spa.env is private (never mirrored). Self-hosters copy this to spa.env.
# See [internal]specs/2026-06-18-public-repo-mirror-design.md §5.4.
#
# SPA_URL: Remote SPA URL served to compatible desktop shells.
#   Empty = all clients use their bundled renderer.
# SPA_IPC_CONTRACT: Minimum IPC contract version the remote SPA requires.
# SPA_VERSION: Git SHA short hash identifying this SPA build.
SPA_URL=https://spa.example.com/index.html
SPA_IPC_CONTRACT=1
SPA_VERSION=0000000
